generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Signature {
  id              String   @id @default(uuid())
  name            String
  title           String
  email           String
  phone           String
  avatarUrl       String   @default("")
  loopingGifUrl   String   @default("")
  landingPageUrl  String   @default("")
  tag             String   @default("")
  isActive        Boolean  @default(true)

  companyLogoUrl  String   @default("")
  website         String   @default("")
  address         String   @default("")
  facebookUrl     String   @default("")
  instagramUrl    String   @default("")
  youtubeUrl      String   @default("")
  taglineLine1    String   @default("")
  taglineLine2    String   @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
